generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Fuente {
  instagram
  facebook
  landing_page
  referido
  otro
}

model Lead {
  id              String    @id @default(uuid())
  nombre          String
  email           String    @unique
  telefono        String?
  fuente          Fuente
  producto_interes String?
  presupuesto     Decimal?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  @@map("leads")
}
